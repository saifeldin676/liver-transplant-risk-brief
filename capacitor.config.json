{
  "appId": "com.meldplus.app",
  "appName": "MELD+",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0D1B2A",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": { "style": "Dark", "backgroundColor": "#0D1B2A" }
  },
  "ios": { "contentInset": "automatic", "backgroundColor": "#0D1B2A" },
  "android": { "backgroundColor": "#0D1B2A", "allowMixedContent": false }
}
