default_platform(:ios)

platform :ios do
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8_BASE64"],
      is_key_content_base64: true,
      in_house: false
    )

    get_certificates(development: false, api_key: api_key)

    get_provisioning_profile(
      app_identifier: "com.meldplus.app",
      api_key: api_key,
      platform: "ios"
    )

    profile = ENV["sigh_com.meldplus.app_appstore"]

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      output_directory: "output",
      output_name: "MELD.ipa",
      xcargs: "-allowProvisioningUpdates CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=3T4MJ4924U CODE_SIGN_IDENTITY=\"Apple Distribution\" PROVISIONING_PROFILE_SPECIFIER=\"#{profile}\" MARKETING_VERSION=1.0 CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "3T4MJ4924U",
        provisioningProfiles: { "com.meldplus.app" => profile }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "output/MELD.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
